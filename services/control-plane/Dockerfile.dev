FROM rust:1.75-alpine AS builder

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache musl-dev openssl-dev cargo

# Copy shared module from root
COPY ../../shared.tar.gz ../shared.tar.gz
RUN tar -xzf ../shared.tar.gz -C ..

# Copy Cargo files
COPY Cargo.toml ./

# Build the application
RUN cargo build --release

# Create a smaller runtime image
FROM alpine:latest

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

# Copy the built binary
COPY --from=builder /app/target/release/drmp-control-plane .

# Copy configuration files
COPY config/ ./config/

# Expose ports
EXPOSE 8080

# Run the application
CMD ["./drmp-control-plane"]